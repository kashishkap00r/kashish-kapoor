---
import Base from './Base.astro';

interface Props {
  title?: string;
  description?: string;
  date?: Date;
  frontmatter?: {
    title?: string;
    description?: string;
    date?: string;
  };
}

const { frontmatter } = Astro.props;
const title = Astro.props.title || frontmatter?.title || '';
const description = Astro.props.description || frontmatter?.description;
const rawDate = Astro.props.date || (frontmatter?.date ? new Date(frontmatter.date) : null);
const formattedDate = rawDate ? rawDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}) : null;
---
<Base title={title} description={description}>
  <article class="prose-container">
    <header class="prose-header">
      <h1>{title}</h1>
      {formattedDate && <time datetime={rawDate?.toISOString()}>{formattedDate}</time>}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
